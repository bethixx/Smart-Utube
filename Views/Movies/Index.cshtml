@model IEnumerable<Smart_Utube.DTOs.Movie.MovieReadDto>
@using Smart_Utube.Models

@{
    ViewData["Title"] = "Movies";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h1>Movies</h1>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            ➕ Add Movie
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <span style="font-size:64px;">🎬</span>
        <h3>No Movies Found</h3>
        <p>There are no movies matching your criteria.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Watch</th>
                    <th>Description</th>
                    <th>Duration</th>
                    <th>Added</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Title</strong>
                        </td>
                        <td>
                            <a asp-controller="Movies"
                               asp-action="Watch"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm">
                                ▶️ Play
                            </a>
                        </td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@item.Description">
                                @item.Description
                            </span>
                        </td>
                        <td>@item.Duration</td>
                        <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                    Details
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                        Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                }

                                @if (User?.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-controller="Favorites"
                                       asp-action="Add"
                                       asp-route-movieId="@item.Id"
                                       class="btn btn-warning btn-sm"
                                       title="Add to Favorites">
                                        ❤️
                                    </a>
                                }
                            </div>

                            @if (ViewBag.Playlists != null && User?.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="PlaylistMovies" asp-action="AddToPlaylist" method="post" class="playlist-form mt-2">
                                    <input type="hidden" name="movieId" value="@item.Id" />
                                    <div class="d-flex gap-2">
                                        <select name="playlistId" class="form-control form-control-sm">
                                            @foreach (var playlist in ViewBag.Playlists)
                                            {
                                                <option value="@playlist.Id">@playlist.Name</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-success btn-sm">
                                            ➕
                                        </button>
                                    </div>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .page-header {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .playlist-form {
        max-width: 250px;
    }

    .playlist-form .d-flex {
        gap: 0.5rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
    }

    .empty-state h3 {
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--text-muted);
        margin-bottom: 0;
    }
</style>
