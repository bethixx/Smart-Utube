@model Smart_Utube.DTOs.Movie.MovieReadDto

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Movie</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.YouTubeUrl)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.YouTubeUrl)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Duration)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Duration)
        </dd>
        <dt class="col-sm-2">
            Created
        </dt>
        <dd class="col-sm-10">
            @Model.CreatedAt.ToString("dd/MM/yyyy")
        </dd>
        <dt class="col-sm-2">
            Rating
        </dt>
        <dd class="col-sm-10">
            ⭐ @Model.AverageRating.ToString("0.0") / 5
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>

    <br />

    <h4>Rate this movie</h4>

    <form asp-controller="Ratings"
          asp-action="Rate"
          method="post">

        <input type="hidden"
               name="movieId"
               value="@Model!.Id" />

        <select name="value" class="form-control">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
        </select>

        <br />

        <button type="submit"
                class="btn btn-success">
            Rate
        </button>
    </form>
    <a asp-controller="Ratings"
       asp-action="Delete"
       asp-route-movieId="@Model.Id"
       class="btn btn-danger mt-2">
        Remove Rating
    </a>

    <br />

    <a asp-controller="Comments"
       asp-action="Create"
       asp-route-movieId="@Model.Id"
       class="btn btn-primary">
        Add comment
    </a>

    <br />

    <h3>Comments</h3>

    @if (Model.Comments.Any())
    {
        @foreach (var comment in Model.Comments)
        {
            <div class="border p-2 mb-2">

                <strong>@comment.UserNickname</strong>

                <p>@comment.Content</p>

                @{
                    var diff = DateTime.Now - comment.CreatedAt;
                    string timeText;

                    if (diff.TotalMinutes < 1)
                    {
                        timeText = "just now";
                    }
                    else if (diff.TotalMinutes < 60)
                    {
                        timeText = $"{(int)diff.TotalMinutes} minutes ago";
                    }
                    else if (diff.TotalHours < 24)
                    {
                        timeText = $"{(int)diff.TotalHours} hours ago";
                    }
                    else
                    {
                        timeText = $"{(int)diff.TotalDays} days ago";
                    }
                }

                <small class="text-muted">
                    @timeText
                </small>

                @if (User.Identity?.IsAuthenticated == true &&
               comment.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                {
                    <form asp-controller="Comments"
                          asp-action="Delete"
                          asp-route-id="@comment.Id"
                          method="post"
                          style="display:inline">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-danger btn-sm">
                            Delete
                        </button>

                    </form>
                }

                @if (User.Identity?.IsAuthenticated == true &&
               comment.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                {
                    <a asp-controller="Comments"
                       asp-action="Edit"
                       asp-route-id="@comment.Id"
                       class="btn btn-warning btn-sm ms-1">
                        Edit
                    </a>
                }

            </div>
        }
    }
    else
    {
        <p>No comments yet.</p>
    }
</div>
