@model IEnumerable<Smart_Utube.Models.Category>

<form class="d-flex me-3" asp-controller="Movies" asp-action="Index" method="get">

    <input class="form-control me-2" type="search" name="searchString" placeholder="Search movies..." />

    <select class="form-control me-2" name="categoryId">

        <option value="">All categories</option>

        @foreach (var c in Model)
        {
            <option value="@c.Id">@c.Name</option>
        }

    </select>

    <button class="btn btn-outline-dark" type="submit">
        Search
    </button>
</form>