@model IEnumerable<Smart_Utube.Models.Favorite>

@{
    ViewData["Title"] = "My Favorites";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h1>❤️ My Favorites</h1>
</div>

@if (Model.Any())
{
    <div class="mb-3">
        <a asp-controller="Movies"
           asp-action="ExportPdf"
           class="btn btn-danger">
            Download Favorites PDF
        </a>
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <span style="font-size:64px;">❤️</span>
        <h3>No Favorites Yet</h3>
        <p>Start adding movies to your favorites to see them here.</p>
        <a asp-controller="Movies" asp-action="Index" class="btn btn-primary mt-3">
            Browse Movies
        </a>
    </div>
}
else
{
    <div class="favorites-grid">
        @foreach (var favorite in Model)
        {
            <div class="favorite-card card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="favorite-info">
                        <h5 class="favorite-title">@favorite.Movie.Title</h5>
                        <a asp-controller="Movies" asp-action="Details" asp-route-id="@favorite.MovieId" class="view-link">
                            View Details →
                        </a>
                    </div>
                    <div class="favorite-actions">
                        <a asp-controller="Movies"
                           asp-action="Watch"
                           asp-route-id="@favorite.MovieId"
                           class="btn btn-primary btn-sm">
                            ▶️ Play
                        </a>
                        <form asp-controller="Favorites"
                              asp-action="Remove"
                              method="post"
                              style="display:inline;">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="movieId" value="@favorite.MovieId" />

                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Remove from favorites?')">
                                ❌
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .page-header {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
    }

    .empty-state h3 {
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--text-muted);
        margin-bottom: 0;
    }

    .favorites-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .favorite-card {
        transition: var(--transition);
    }

    .favorite-card:hover {
        border-color: var(--primary);
    }

    .favorite-title {
        margin-bottom: 0.25rem;
        color: var(--text-primary);
    }

    .view-link {
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
    }

    .favorite-actions {
        display: flex;
        gap: 0.5rem;
    }
</style>
