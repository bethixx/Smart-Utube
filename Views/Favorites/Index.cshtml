@model IEnumerable<Smart_Utube.Models.Favorite>

<h1>My Favorites</h1>

@if (!Model.Any())
{
    <p>No favorite movies yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Movie</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var favorite in Model)
            {
                <tr>
                    <td>@favorite.Movie.Title</td>
                    <td>
                        <a asp-action="Remove"
                           asp-route-movieId="@favorite.MovieId"
                           class="btn btn-danger">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}