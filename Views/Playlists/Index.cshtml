@model IEnumerable<Smart_Utube.Models.Playlist>

@{
    ViewData["Title"] = "My Playlists";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h1>📂 My Playlists</h1>
    <a asp-action="Create" class="btn btn-primary">
        ➕ New Playlist
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <span style="font-size:64px;">📂</span>
        <h3>No Playlists Yet</h3>
        <p>Create your first playlist to organize your favorite movies.</p>
        <a asp-action="Create" class="btn btn-primary mt-3">
            Create Playlist
        </a>
    </div>
}
else
{
    <div class="playlists-grid">
        @foreach (var item in Model)
        {
            <div class="playlist-card card">
                <div class="card-body">
                    <div class="playlist-icon">
                        📂
                    </div>
                    <h5 class="playlist-name">@item.Name</h5>
                    <div class="playlist-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                            👁️ View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                            ✏️ Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this playlist?')">
                            🗑️
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .page-header {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }
    
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
    }
    
    .empty-state h3 {
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }
    
    .empty-state p {
        color: var(--text-muted);
        margin-bottom: 0;
    }
    
    .playlists-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    
    .playlist-card {
        transition: var(--transition);
    }
    
    .playlist-card:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
    }
    
    .playlist-icon {
        width: 48px;
        height: 48px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }
    
    .playlist-name {
        color: var(--text-primary);
        margin-bottom: 1rem;
        font-size: 1.125rem;
    }
    
    .playlist-actions {
        display: flex;
        gap: 0.5rem;
    }
</style>
